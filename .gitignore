# ── Maven local repository cache (never commit this) ──────────────────────────
.m2repo/

# ── Java / Maven build output ─────────────────────────────────────────────────
target/
*.class
*.jar
*.war
*.ear
*.nar
hs_err_pid*

# ── Node / frontend build output ──────────────────────────────────────────────
node_modules/
dist/
dist-ssr/
*.local

# ── Environment / secrets ─────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── IDEs ──────────────────────────────────────────────────────────────────────
.idea/
*.iml
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Security doc drafts / backups ─────────────────────────────────────────────
*_backup.md
*copy.md
